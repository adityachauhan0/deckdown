{
  "name": "deckdown",
  "version": "1.0.0",
  "description": "Local-first Markdown presentation compiler for PDF, PNG, and PPTX output",
  "main": "./src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "deckdown": "./src/cli.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm test -- --watch",
    "release-check": "node scripts/release-check.js",
    "prepublishOnly": "npm run release-check"
  },
  "keywords": [
    "presentation",
    "markdown",
    "pdf",
    "slides",
    "deckdown"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityachauhan0/DeskDown.git"
  },
  "homepage": "https://github.com/adityachauhan0/DeskDown#readme",
  "bugs": {
    "url": "https://github.com/adityachauhan0/DeskDown/issues"
  },
  "files": [
    "LICENSE",
    "README.md",
    "src/"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "pdfkit": "^0.15.0",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.34.5",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
