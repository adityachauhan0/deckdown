    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "commander": "^12.0.0",
    "dompurify": "^3.3.3",
    "esbuild": "^0.28.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.0.2",
    "mathjax-full": "^3.2.1",
    "mermaid": "^11.14.0",
    "pdfkit": "^0.15.0",
    "pptxgenjs": "^3.12.0",
    "puppeteer-core": "^24.40.0",
