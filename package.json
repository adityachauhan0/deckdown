  "description": "Markdown presentation engine for AI agents with deterministic PDF, PNG, and PPTX output",
  "main": "./src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "deckdown": "src/cli.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm test -- --watch",
    "release-check": "node scripts/release-check.js",
    "prepublishOnly": "npm run release-check"
  },
  "keywords": [
    "ai-agents",
    "ai-agent-tools",
    "presentation",
    "markdown",
    "pptx",
    "png",
    "pdf",
    "slides",
    "powerpoint",
    "powerpoint-automation",
    "powerpoint-generation",
    "markdown-to-pptx",
    "slides-as-code",
    "docs-as-code",
    "local-first",
    "developer-tools",
    "agentic-workflows",
    "automation",
    "deckdown"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityachauhan0/deckdown.git"
  },
  "homepage": "https://github.com/adityachauhan0/deckdown#readme",
  "bugs": {
    "url": "https://github.com/adityachauhan0/deckdown/issues"
  },
  "files": [
    "LICENSE",
    "README.md",
    "src/"
